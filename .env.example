# Environment variables for FirstTaps MV3D Browser
# Copy this file to .env.local and fill in your actual API keys
# The .env.local file is gitignored and will not be committed

# ============================================================================
# SERVER-SIDE API KEYS (Cloudflare Worker Secrets)
# ============================================================================
# These keys are now stored server-side in Cloudflare Worker secrets.
# You do NOT need to add them to .env.local anymore!
# To set/update: cd cloudflare-worker && wrangler secret put <KEY_NAME>

# YouTube Data API v3 Key - HANDLED BY CLOUDFLARE WORKER
# Get from: https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=<stored in Worker secret>

# Vimeo Access Token - HANDLED BY CLOUDFLARE WORKER
# Get from: https://developer.vimeo.com/apps
# VIMEO_ACCESS_TOKEN=<stored in Worker secret>

# ============================================================================
# OPTIONAL CLIENT-SIDE API KEYS
# ============================================================================
# These are optional and only needed if you want extended functionality

# SoundCloud Client ID (optional for trending tracks)
# Get from: https://soundcloud.com/you/apps (register an app)
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id_here

# GitHub Personal Access Token (for furniture sharing via Gist)
# Get from: https://github.com/settings/tokens (requires 'gist' scope)
# WARNING: Browser apps expose tokens in page source. Only use tokens with 'gist' scope.
# Monitor GitHub for unauthorized activity: https://github.com/settings/security-log
GITHUB_TOKEN=your_github_token_here

# Optional: TikTok trending source URL (if you have one)
TIKTOK_TRENDING_URL=

# Optional: Instagram trending source URL (if you have one)
INSTAGRAM_TRENDING_URL=
