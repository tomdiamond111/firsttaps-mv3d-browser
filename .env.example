# Environment variables for FirstTaps MV3D Browser
# Copy this file to .env.local and fill in your actual API keys
# The .env.local file is gitignored and will not be committed

# YouTube Data API v3 Key
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Vimeo Access Token
# Get from: https://developer.vimeo.com/apps
VIMEO_ACCESS_TOKEN=your_vimeo_access_token_here

# SoundCloud Client ID (optional for trending tracks)
# Get from: https://soundcloud.com/you/apps (register an app)
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id_here

# GitHub Personal Access Token (for furniture sharing via Gist)
# Get from: https://github.com/settings/tokens (requires 'gist' scope)
GITHUB_TOKEN=your_github_token_here

# Optional: TikTok trending source URL (if you have one)
TIKTOK_TRENDING_URL=

# Optional: Instagram trending source URL (if you have one)
INSTAGRAM_TRENDING_URL=
