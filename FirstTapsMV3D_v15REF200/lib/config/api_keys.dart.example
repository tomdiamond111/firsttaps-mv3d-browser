/// API Keys Configuration Template
/// 
/// To set up:
/// 1. Copy this file to api_keys.dart (same directory)
/// 2. Replace placeholder values with your actual keys
/// 3. Never share or commit api_keys.dart (it's in .gitignore)

class ApiKeys {
  // GitHub Personal Access Token for Gist creation
  // Generate at: https://github.com/settings/tokens
  // Required scope: 'gist' only
  static const String githubToken = 'YOUR_GITHUB_TOKEN_HERE';

  // Add other API keys here as needed
  // static const String youtubeApiKey = 'YOUR_KEY_HERE';
  // static const String spotifyClientId = 'YOUR_ID_HERE';
}
